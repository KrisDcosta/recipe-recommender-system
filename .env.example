# Local runtime
MODEL_DIR=models
MODEL_NAME=time_aware_mf
RECIPES_CSV=data/dataset/RAW_recipes.csv
TRAIN_INTERACTIONS_CSV=data/dataset/interactions_train.csv
PORT=8080
