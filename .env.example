# Local runtime
MODEL_DIR=models
MODEL_NAME=time_aware_mf
RECIPES_CSV=data/dataset/RAW_recipes.csv
TRAIN_INTERACTIONS_CSV=data/dataset/interactions_train.csv
PORT=8080
LOG_LEVEL=info

# Cloud Run runtime. Upload model artifacts and recipe metadata to GCS, then
# set these as GitHub Actions repository variables for deploy.yml.
MODEL_GCS_URI=gs://YOUR_BUCKET/models
RECIPES_GCS_URI=gs://YOUR_BUCKET/data/RAW_recipes.csv

# Optional LLM explanations. Put real keys only in local .env, GitHub Secrets,
# or a cloud secret manager. Never commit real API keys.
ENABLE_LLM_EXPLANATIONS=false
LLM_PROVIDER=xai
LLM_BASE_URL=https://api.x.ai/v1
LLM_MODEL=grok-3-mini
XAI_API_KEY=
